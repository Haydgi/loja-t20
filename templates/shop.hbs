{{!-- templates/shop.hbs — Janela principal da Loja --}}
<div class="t20-loja-app">

  {{!-- ── Cabeçalho: saldo do personagem ── --}}
  <div class="shop-wealth-bar">
    <span class="wealth-label"><i class="fas fa-coins"></i> Saldo de <strong>{{actor.name}}</strong>:</span>
    <span class="wealth-coin gold">{{wealth.to}} <abbr title="Tibar de Ouro">TO</abbr></span>
    <span class="wealth-coin silver">{{wealth.tp}} <abbr title="Tibar de Prata">TP</abbr></span>
    <span class="wealth-coin copper">{{wealth.tc}} <abbr title="Tibar de Cobre">TC</abbr></span>
    <span class="wealth-total">(= {{wealth.totalSilver}} TP total)</span>
    <button type="button" class="btn-open-cart" title="Abrir carrinho">
      <i class="fas fa-shopping-cart"></i>
    </button>
  </div>

  {{!-- ── Filtros ── --}}
  <div class="shop-filters">
    <div class="filter-group shop-mode-toggle">
      <button class="mode-btn {{#if (eq mode "buy")}}active{{/if}}" data-mode="buy" title="Comprar">
        <i class="fas fa-store"></i>
        <span>Comprar</span>
      </button>
      <button class="mode-btn {{#if (eq mode "sell")}}active{{/if}}" data-mode="sell" title="Vender">
        <i class="fas fa-hand-holding-usd"></i>
        <span>Vender</span>
      </button>
    </div>

    <div class="filter-group">
      <i class="fas fa-search"></i>
      <input type="text" class="shop-search-input" placeholder="Buscar item…" value="{{search}}">
    </div>

    <div class="filter-group">
      <label>Ordenar</label>
      <select class="shop-sort">
        <option value="name"       {{#if (eq sortBy "name")}}selected{{/if}}>Nome</option>
        <option value="price-asc"  {{#if (eq sortBy "price-asc")}}selected{{/if}}>Preço (menor)</option>
        <option value="price-desc" {{#if (eq sortBy "price-desc")}}selected{{/if}}>Preço (maior)</option>
        <option value="type"       {{#if (eq sortBy "type")}}selected{{/if}}>Tipo</option>
      </select>
    </div>

    {{#if (eq mode "buy")}}
      <div class="filter-group shop-affordable-toggle">
        <label class="checkbox">
          <input type="checkbox" class="shop-affordable-only" {{#if affordableOnly}}checked{{/if}}>
          <span>Somente itens que posso comprar</span>
        </label>
      </div>
    {{/if}}

    {{#if (eq mode "sell")}}
      <div class="filter-group sell-percent-group">
        <label>Venda</label>
        <input type="range" class="shop-sell-percent" min="1" max="100" step="1" value="{{sellPercent}}">
        <input type="number" class="shop-sell-percent-input" min="1" max="100" step="1" value="{{sellPercent}}">
        <span class="sell-percent-label">%</span>
      </div>
    {{/if}}


    <span class="filter-count">{{totalItems}} ite{{#if (eq totalItems 1)}}m{{else}}ns{{/if}}</span>
  </div>

  <div class="shop-content">
    <aside class="shop-side-filters">
      <div class="side-filter-header">
        <i class="fas fa-filter"></i>
        <span>Filtros avançados</span>
        <button type="button" class="btn-filter-reset" title="Limpar filtros">
          <i class="fas fa-eraser"></i>
        </button>
      </div>

      <div class="side-filter-match">
        <label class="filter-option">
          <input type="radio" name="shop-filter-match" value="any">
          <span>Qualquer filtro</span>
        </label>
        <label class="filter-option">
          <input type="radio" name="shop-filter-match" value="all">
          <span>Todos os filtros</span>
        </label>
      </div>

      <details class="side-filter-group" data-group="weapons">
        <summary>
          <span>Armas</span>
          <label class="filter-option filter-option-inline">
            <input type="checkbox" class="shop-filter-checkbox" data-tag="cat:arma">
          </label>
        </summary>
        <div class="filter-options">
          <div class="filter-subgroup">
            <div class="filter-subtitle">Propriedades</div>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="prop:ada"><span>Adaptável</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="prop:agi"><span>Ágil</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="prop:alo"><span>Alongada</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="prop:des"><span>Desbalanceada</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="prop:dupla"><span>Dupla</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="prop:ver"><span>Versátil</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="prop:hib"><span>Híbrida</span></label>
          </div>

          <div class="filter-subgroup">
            <div class="filter-subtitle">Propósito</div>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="purpose:corpo-a-corpo"><span>Corpo a corpo</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="purpose:corpo-a-corpo-arremesso"><span>Corpo a corpo e arremesso</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="purpose:disparo"><span>Disparo</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="purpose:arremesso"><span>Arremesso</span></label>
          </div>

          <div class="filter-subgroup">
            <div class="filter-subtitle">Empunhadura</div>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="grip:leve"><span>Leve</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="grip:uma"><span>Uma mão</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="grip:duas"><span>Duas mãos</span></label>
          </div>

          <div class="filter-subgroup">
            <div class="filter-subtitle">Proficiência</div>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="prof:marcial"><span>Marcial</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="prof:simples"><span>Simples</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="prof:exotica"><span>Exótica</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="prof:fogo"><span>Arma de fogo</span></label>
          </div>
        </div>
      </details>

      <details class="side-filter-group" data-group="equipment">
        <summary>
          <span>Equipamento</span>
          <label class="filter-option filter-option-inline">
            <input type="checkbox" class="shop-filter-checkbox" data-tag="cat:equipamento">
          </label>
        </summary>
        <div class="filter-options">
          <div class="filter-subgroup">
            <div class="filter-subtitle">Tipo</div>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="equip:escudo"><span>Escudo</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="equip:leve"><span>Armadura leve</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="equip:pesada"><span>Armadura pesada</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="equip:acessorio"><span>Acessório</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="equip:ferramenta"><span>Ferramenta</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="equip:esoterico"><span>Esotérico</span></label>
          </div>

          <div class="filter-subgroup">
            <div class="filter-subtitle">Tipo de uso</div>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="usage:hand"><span>Empunhado</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="usage:body"><span>Vestido</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="usage:both"><span>Ambos</span></label>
          </div>
        </div>
      </details>

      <details class="side-filter-group" data-group="treasure">
        <summary>
          <span>Tesouro</span>
          <label class="filter-option filter-option-inline">
            <input type="checkbox" class="shop-filter-checkbox" data-tag="cat:tesouro">
          </label>
        </summary>
        <div class="filter-options">
          <span class="filter-hint">Itens de tesouro/espólio.</span>
        </div>
      </details>

      <details class="side-filter-group" data-group="consumables">
        <summary>
          <span>Consumíveis</span>
          <label class="filter-option filter-option-inline">
            <input type="checkbox" class="shop-filter-checkbox" data-tag="cat:consumivel">
          </label>
        </summary>
        <div class="filter-options">
          <div class="filter-subgroup">
            <div class="filter-subtitle">Tipo</div>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="cons:ammo"><span>Munição</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="cons:scroll"><span>Pergaminho</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="cons:alchemy"><span>Alquímico</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="cons:potion"><span>Poção</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="cons:material"><span>Material</span></label>
            <label class="filter-option"><input type="checkbox" class="shop-filter-checkbox" data-tag="cons:food"><span>Comida</span></label>
          </div>
        </div>
      </details>
    </aside>

    {{!-- ── Lista de itens ── --}}
    <div class="shop-items-list">

    {{#if loading}}
      <div class="shop-loading">
        <i class="fas fa-spinner fa-spin fa-2x"></i>
        <p>Carregando itens…</p>
      </div>

    {{else if items.length}}
      <table class="shop-table">
        <thead>
          <tr>
            <th class="col-img"></th>
            <th class="col-name">Item</th>
            <th class="col-type">Tipo</th>
            <th class="col-weight">Peso</th>
            <th class="col-price">{{#if (eq mode "sell")}}Venda{{else}}Preço{{/if}}</th>
            <th class="col-action"></th>
          </tr>
        </thead>
        <tbody>
          {{#each items}}
          <tr class="shop-item-row {{#if (eq ../mode "buy")}}{{#unless canAfford}}cannot-afford{{/unless}}{{/if}}">
            <td class="col-img">
              <img class="shop-item-img" src="{{img}}" alt="{{name}}"
                   data-uuid="{{uuid}}" draggable="true" title="Arrastar para cena/ficha">
            </td>
            <td class="col-name">
              <span class="shop-item-name" title="Clique para abrir o item" data-uuid="{{uuid}}">{{name}}</span>
              {{#if source}}<span class="item-source">{{source}}</span>{{/if}}
              {{#if description}}
              <div class="shop-item-desc hidden">{{{description}}}</div>
              {{/if}}
            </td>
            <td class="col-type"><span class="type-badge">{{typeLabel}}</span></td>
            <td class="col-weight">{{espacos}} Esp.</td>
            <td class="col-price">
              <span class="price-tag {{#if (eq ../mode "buy")}}{{#unless canAfford}}too-expensive{{/unless}}{{/if}}">
                {{#if (eq ../mode "sell")}}
                  {{sellPriceDisplay}}
                {{else}}
                  {{precoDisplay}}
                {{/if}}
              </span>
            </td>
            <td class="col-action">
              {{#if (eq ../mode "sell")}}
                <button class="btn-sell" data-item-id="{{itemId}}" title="Vender {{name}}">
                  <i class="fas fa-hand-holding-usd"></i>
                </button>
              {{else}}
                <div class="buy-actions">
                  <button class="btn-buy btn-buy-small {{#unless canAfford}}disabled{{/unless}}"
                          data-uuid="{{uuid}}"
                          {{#unless canAfford}}disabled title="Sem moedas suficientes"{{/unless}}
                          title="Comprar {{name}}">
                    <i class="fas fa-coins"></i>
                  </button>
                  <button class="btn-cart" data-uuid="{{uuid}}" title="Adicionar ao carrinho">
                    <i class="fas fa-cart-plus"></i>
                  </button>
                </div>
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

    {{else}}
      <div class="shop-empty">
        <i class="fas fa-store-slash fa-3x"></i>
        <p>Nenhum item encontrado{{#if search}} para "<em>{{search}}</em>"{{/if}}.</p>
        <p class="hint">Verifique os filtros ou configure os compêndios nas Configurações do Módulo.</p>
      </div>
    {{/if}}

    </div>{{!-- /shop-items-list --}}
  </div>{{!-- /shop-content --}}
</div>{{!-- /t20-loja-app --}}
